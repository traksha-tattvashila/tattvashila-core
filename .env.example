# Node environment: development | production | test
NODE_ENV=development

# Minimum log level: debug | info | warn | error
LOG_LEVEL=info

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/tattvashila

# ── Production messaging providers (Sprint 8) ─────────────────────────────
# Required only when NODE_ENV=production. In development and test, the
# built-in dev providers are used instead and these variables are ignored.

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP email (works with any SMTP-compatible provider: SES, SendGrid, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# ── Authentication Infrastructure (Sprint 9) ──────────────────────────────
# Required in all environments — JWT access tokens are always signed with
# this secret. Use a long, random value in production.
AUTH_JWT_SECRET=

# Optional — defaults shown.
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
